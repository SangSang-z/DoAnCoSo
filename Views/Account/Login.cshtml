@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/wwwroot/css/reset.css" asp-append-version="true" />
    <title>@ViewData["Title"] - Website_for_selling_car_tickets</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="~/css_admin/admin_layout.css" asp-append-version="true" />
</head>

<body>
    <header>
        <div id="loginForm" class="login-form">
            <form action="@Url.Action("Login", "Account")" method="post">
                <button class="close-btn" type="button" onclick="closeLoginForm()">×</button> <!-- Dấu X để đóng -->
                <h2 class="login-title">Đăng nhập</h2>

                <label for="phone">Số điện thoại</label>
                <input type="text" id="phone" name="phone" placeholder="Nhập số điện thoại" required>

                <label for="password">Mật khẩu</label>
                <input type="password" id="password" name="password" placeholder="Nhập mật khẩu" required>

                <button class="login-account" type="submit">Đăng Nhập</button>
            </form>
    </header>
</body>
